# =============================================================================
# CIRCULAR EXCHANGE - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# Appwrite Configuration (get these from https://cloud.appwrite.io)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here
APPWRITE_DATABASE_ID=circular_exchange_db

# Collection IDs (auto-created by setup script)
APPWRITE_USERS_COLLECTION_ID=users_profile
APPWRITE_PRODUCTS_COLLECTION_ID=products
APPWRITE_TRANSACTIONS_COLLECTION_ID=transactions

# JWT Secret (any random long string)
JWT_SECRET=change-this-to-a-random-secret-string-at-least-32-chars

# MongoDB Configuration (required for feedback storage)
MONGODB_URI=mongodb://localhost:27017
MONGO_DB_NAME=circular_exchange

# Server Port
PORT=8080
